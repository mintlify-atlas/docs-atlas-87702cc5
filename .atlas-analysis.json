  "keyFeatures": [
    "TypeScript SDK with strongly-typed builders for mod generation",
    "CLI tool (civ7) for managing game resources (zip/unzip/crawl/explore)",
    "BFS XML crawler that produces dependency graphs in JSON, DOT, and SVG",
    "Interactive HTML graph viewer for exploring game data relationships",
    "Comprehensive game constants for units, abilities, effects, terrains, resources",
    "Localization support for multiple languages",
    "Plugin libraries for file operations, graph crawling, and mod management",
    "Monorepo structure with playground for examples and experimentation"
  ],
  "publicApiSurface": [
    "Mod class — orchestrates mod building and generates .modinfo",
    "UnitBuilder — create custom units with stats, costs, abilities",
    "CivilizationBuilder — define new civilizations with traits",
    "ConstructibleBuilder — create buildings and improvements",
    "ProgressionTreeBuilder — build civic and tech trees",
    "ModifierBuilder — create game modifiers and effects",
    "TraditionBuilder — add new policy cards",
    "UniqueQuarterBuilder — design unique districts",
    "LeaderUnlockBuilder — configure leader bonuses",
    "ImportFileBuilder — import SQL files and custom assets",
    "XmlFile / BaseFile — low-level file generation abstractions",
    "civ7 data crawl <seed> — crawl XML resources and output graph",
    "civ7 data explore <seed> — full pipeline: crawl → render → open viewer",
    "civ7 data render <input> — render DOT to SVG",
    "civ7 data slice <manifest> — copy files from manifest",
    "civ7 data zip <profile> — create resource archives",
    "civ7 data unzip <profile> — extract resource archives",
    "civ7 mod git — manage mods via git subtree",
    "UNIT, ABILITY, EFFECT, TERRAIN, RESOURCE constants — game entity enums"
  ]
}
